# Use long, random values outside development.
SESSION_SECRET="replace-with-a-random-secret"

# Telegram integration. These values can also be configured in the UI.
TELEGRAM_ENABLED="false"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# Reserved for the PostgreSQL migration. The app still uses the JSON database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

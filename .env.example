# Use long, random values outside development.
SESSION_SECRET="replace-with-a-random-secret"

# Canonical public URL. Vercel also provides VERCEL_PROJECT_PRODUCTION_URL automatically.
APP_URL="http://localhost:3000"

# Telegram integration. These values can also be configured in the UI.
TELEGRAM_ENABLED="false"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# Groq speech-to-text integration for Telegram voice and audio messages.
GROQ_API_KEY=""
GROQ_TRANSCRIPTION_TIMEOUT_MS="60000"

# ElevenLabs text-to-speech for patients who require assisted audio messages.
ELEVENLABS_API_KEY=""
ELEVENLABS_TTS_MODEL="eleven_flash_v2_5"
ELEVENLABS_VOICE_ID="JBFqnCBsd6RMkjVDRZzb"
ELEVENLABS_TTS_TIMEOUT_MS="60000"

# Supabase transaction pooler for the serverless application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"

# Supabase direct/session connection used only by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AppMeta {
  id        String   @id @default("app")
  version   Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String    @id
  name         String
  email        String    @unique
  passwordHash String
  role         String
  specialty    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  patients     Patient[] @relation("ResponsiblePatients")
}

model Patient {
  id                      String     @id
  name                    String
  age                     Int
  phone                   String
  condition               String
  notes                   String
  responsibleUserId       String?
  preferredResponseFormat String
  requiresAudioMessages    Boolean    @default(false)
  preferredChannel        String
  contactWindowStart      String
  contactWindowEnd        String
  telegramChatId          String?    @unique
  telegramUsername        String?
  telegramLinkToken       String     @unique
  telegramLinkedAt        DateTime?
  status                  String
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  responsibleUser         User?      @relation("ResponsiblePatients", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  schedules               Schedule[]
  messages                Message[]
  alerts                  Alert[]

  @@index([phone])
  @@index([responsibleUserId])
  @@index([status])
}

model Question {
  id              String     @id
  title           String
  text            String
  simpleText      String
  theme           String
  responseType    String
  defaultTimes    String[]
  isActive        Boolean    @default(true)
  createdByUserId String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  schedules       Schedule[]
  messages        Message[]

  @@index([isActive])
  @@index([createdByUserId])
}

model Schedule {
  id              String    @id
  patientId       String
  questionId      String
  label           String
  time            String
  timezone        String
  daysOfWeek      Int[]
  active          Boolean   @default(true)
  lastDispatchKey String?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([patientId])
  @@index([questionId])
  @@index([active])
}

model Message {
  id                String    @id
  patientId         String
  questionId        String?
  scheduleId        String?
  channel           String
  direction         String
  type              String
  body              String
  status            String
  providerMessageId String?
  whatsappMessageId String?
  telegramMessageId String?
  sentAt            DateTime?
  receivedAt        DateTime?
  replyToMessageId  String?
  errorMessage      String?
  metadata          Json?
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  question          Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  schedule          Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@unique([channel, providerMessageId])
  @@index([patientId, direction])
  @@index([status])
  @@index([sentAt])
  @@index([receivedAt])
}

model Alert {
  id               String    @id
  patientId        String
  level            String
  title            String
  description      String
  type             String
  status           String
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?
  assignedToUserId String?
  sourceMessageId  String?
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, status])
  @@index([assignedToUserId])
  @@index([sourceMessageId])
}

model WhatsAppSettings {
  id                String    @id @default("default")
  enabled           Boolean   @default(false)
  accessToken       String    @default("")
  phoneNumberId     String    @default("")
  businessAccountId String    @default("")
  verifyToken       String    @default("")
  appSecret         String    @default("")
  apiVersion        String    @default("v23.0")
  updatedAt         DateTime?
}

model TelegramSettings {
  id            String    @id @default("default")
  enabled       Boolean   @default(false)
  botToken      String    @default("")
  botUsername   String    @default("")
  webhookSecret String    @default("")
  updatedAt     DateTime?
}
